---
interface Props {
  src: string;
  poster?: string;
  title: string;
}
const { src, poster, title } = Astro.props;
---

<video
  class="w-full rounded-xl border"
  controls
  autoplay
  muted
  loop
  playsinline
  preload="metadata"
  poster={poster}
  aria-label={title}
>
  <source src={src} type="video/mp4" />
</video>