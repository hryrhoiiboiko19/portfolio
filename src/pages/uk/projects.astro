---
import BaseLayout from "@layouts/BaseLayout.astro";
import Section from "@components/Section.astro";
import ProjectCard from "@components/ProjectCard.astro";
import ProjectGallery from "@components/ProjectGallery.astro";
import ContactCTA from "@components/ContactCTA.astro";
import { useTranslations } from "@i18n/index";
import { getProjects, resolveProject } from "@data/index";
import { SITE } from "@consts";

const locale = "uk" as const;
const t = useTranslations(locale);
const projects = getProjects().map((p) => resolveProject(p, locale));
---

<BaseLayout locale={locale} path="/projects" title={`${t.projects.title} — ${t.meta.siteTitle}`} description={t.projects.subtitle}>
  <Section title={t.projects.title} subtitle={t.projects.subtitle}>
    <div class="space-y-10">
      {
        projects.map((p) => (
          <>
            <ProjectCard
              title={p.title}
              description={p.description}
              stack={p.stack}
              stackLabel={t.projects.stack}
              liveUrl={p.liveUrl}
              repoUrl={p.repoUrl}
              viewLiveLabel={t.projects.viewLive}
              mainImage={p.mainImage}
              mainImageAlt={p.mainImageAlt}
              groupId={p.id}
            />
            <ProjectGallery
              images={p.carouselImages}
              title={t.projects.galleryTitle}
              groupId={p.id}
            />
          </>
        ))
      }
    </div>
  </Section>

  <ContactCTA
    title={t.contact.title}
    subtitle={t.contact.subtitle}
    telegram={{ href: SITE.telegram, label: t.contact.telegram }}
    email={{ href: `mailto:${SITE.email}`, label: t.contact.email }}
  />
</BaseLayout>