---
import Button from "@components/Button.astro";

interface Props {
  title: string;
  subtitle: string;
  telegram: { href: string; label: string };
  email: { href: string; label: string };
}

const { title, subtitle, telegram, email } = Astro.props;
---

<section
  class="mx-auto my-16 w-full max-w-5xl px-4 sm:px-6"
  id="contact"
>
  <div
    class="card flex flex-col items-start gap-4 p-8 sm:flex-row sm:items-center sm:justify-between sm:p-12"
    style="background: linear-gradient(135deg, var(--accent-soft), transparent);"
  >
    <div>
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h2>
      <p class="mt-2 text-muted">{subtitle}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <Button href={telegram.href} external variant="primary">
        {telegram.label}
      </Button>
      <Button href={email.href} variant="outline">
        {email.label}
      </Button>
    </div>
  </div>
</section>