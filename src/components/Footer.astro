---
import { SOCIALS, YEAR } from "@consts";
import { useTranslations, type Locale } from "@i18n/index";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<footer class="mt-24 border-t" style="border-color: var(--border);">
  <div class="container-page py-10">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <p class="text-sm text-subtle">
        © {YEAR} — {t.meta.siteTitle.split("—")[0].trim()}. {t.footer.rights}
      </p>
      <nav class="flex items-center gap-4" aria-label="Socials">
        {
          SOCIALS.map((s) => (
            <a
              href={s.href}
              class="text-sm text-muted transition-colors hover:text-[var(--accent)]"
              rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
              target={s.href.startsWith("http") ? "_blank" : undefined}
            >
              {s.label}
            </a>
          ))
        }
      </nav>
    </div>
    <p class="mt-4 text-center text-xs text-subtle">{t.footer.builtWith}</p>
  </div>
</footer>