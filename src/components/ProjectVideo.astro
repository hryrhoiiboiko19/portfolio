---
interface Props {
  src: string;
  poster?: string;
  title: string;
}
const { src, poster, title } = Astro.props;
---

<video
  class="mx-auto block max-h-[60vh] w-auto max-w-[28rem] rounded-xl border sm:max-w-sm"
  controls
  autoplay
  muted
  loop
  playsinline
  preload="metadata"
  poster={poster}
  aria-label={title}
>
  <source src={src} type="video/mp4" />
</video>