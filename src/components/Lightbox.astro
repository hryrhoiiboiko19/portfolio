---
// Global lightbox modal. Any element with [data-lightbox] containing a
// data-lightbox-src attribute will trigger the modal. Images rendered with
// this component's data-* contract (see ProjectCard / ProjectGallery).
---

<div
  id="lightbox"
  class="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Image preview"
  hidden
>
  <button
    type="button"
    class="lightbox-close"
    aria-label="Close"
    data-lightbox-close
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <button type="button" class="lightbox-prev" aria-label="Previous" data-lightbox-prev hidden>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <figure class="lightbox-figure">
    <img id="lightbox-img" alt="" />
    <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
  </figure>
  <button type="button" class="lightbox-next" aria-label="Next" data-lightbox-next hidden>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.85);
    padding: 1rem;
    backdrop-filter: blur(2px);
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox-figure {
    max-width: min(96vw, 1100px);
    max-height: 88vh;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .lightbox-figure img {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
  }
  .lightbox-caption {
    color: #f3f4f6;
    font-size: 0.9rem;
    text-align: center;
  }
  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }
  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover {
    background: rgba(255, 255, 255, 0.24);
  }
  .lightbox-close {
    top: 1rem;
    right: 1rem;
    transform: none;
  }
  .lightbox-prev { left: 1rem; }
  .lightbox-next { right: 1rem; }
  .lightbox-close svg,
  .lightbox-prev svg,
  .lightbox-next svg {
    width: 1.5rem;
    height: 1.5rem;
  }
</style>

<script>
  (function () {
    interface Item {
      src: string;
      alt: string;
      group?: string;
    }

    const root = document.getElementById("lightbox");
    if (!root) return;
    const img = document.getElementById("lightbox-img") as HTMLImageElement | null;
    const cap = document.getElementById("lightbox-caption") as HTMLElement | null;
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-lightbox-next]");
    if (!img || !cap) return;

    const items = new Map<string, Item[]>();
    let currentGroup: string | null = null;
    let currentIdx = 0;

    function buildIndex() {
      items.clear();
      const nodes = document.querySelectorAll<HTMLElement>("[data-lightbox]");
      nodes.forEach((node) => {
        const src = node.getAttribute("data-lightbox-src");
        if (!src) return;
        const alt = node.getAttribute("data-lightbox-alt") ?? "";
        const group = node.getAttribute("data-lightbox-group") ?? "default";
        const list = items.get(group) ?? [];
        list.push({ src, alt, group });
        items.set(group, list);
      });
    }

    function show(group: string, src: string) {
      const list = items.get(group);
      if (!list || list.length === 0) return;
      currentGroup = group;
      currentIdx = Math.max(
        0,
        list.findIndex((it) => it.src === src)
      );
      render();
      root!.removeAttribute("hidden");
      document.body.style.overflow = "hidden";
    }

    function render() {
      if (!currentGroup) return;
      const list = items.get(currentGroup);
      if (!list) return;
      const item = list[currentIdx];
      if (!item) return;
      img!.src = item.src;
      img!.alt = item.alt;
      cap!.textContent = item.alt;
      const multi = list.length > 1;
      if (prevBtn) prevBtn.hidden = !multi;
      if (nextBtn) nextBtn.hidden = !multi;
    }

    function close() {
      root!.setAttribute("hidden", "");
      document.body.style.overflow = "";
      currentGroup = null;
      currentIdx = 0;
    }

    function step(delta: number) {
      if (!currentGroup) return;
      const list = items.get(currentGroup);
      if (!list) return;
      const n = list.length;
      if (n === 0) return;
      currentIdx = (currentIdx + delta + n) % n;
      render();
    }

    root.addEventListener("click", (e) => {
      const t = e.target as Element | null;
      if (!(t instanceof Element)) return;
      if (t === root || t.closest("[data-lightbox-close]")) {
        close();
        return;
      }
      if (t.closest("[data-lightbox-prev]")) {
        step(-1);
        return;
      }
      if (t.closest("[data-lightbox-next]")) {
        step(1);
        return;
      }
    });

    document.addEventListener("click", (e) => {
      const t = e.target as Element | null;
      if (!(t instanceof Element)) return;
      const trigger = t.closest<HTMLElement>("[data-lightbox-src]");
      if (!trigger || trigger.hasAttribute("data-lightbox-static")) return;
      e.preventDefault();
      const src = trigger.getAttribute("data-lightbox-src")!;
      const group = trigger.getAttribute("data-lightbox-group") ?? "default";
      buildIndex();
      show(group, src);
    });

    document.addEventListener("keydown", (e) => {
      if (root!.hasAttribute("hidden")) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft") step(-1);
      else if (e.key === "ArrowRight") step(1);
    });

    document.addEventListener("astro:page-load", buildIndex);
    buildIndex();
  })();
</script>